{
  "name": "svode",
  "version": "0.0.1",
  "private": true,
  "author": "Kamnev Ilya",
  "repository": "https://github.com/venmakli/svode",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --cwd apps/desktop dev",
    "build": "bun run --cwd apps/desktop build",
    "tauri": "bun run --cwd apps/desktop tauri",
    "check:local": "bun run --cwd apps/desktop typecheck && cargo check --manifest-path=apps/desktop/src-tauri/Cargo.toml",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "overrides": {
    "@tiptap/core": "3.20.2",
    "@tiptap/pm": "3.20.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.1"
  }
}
